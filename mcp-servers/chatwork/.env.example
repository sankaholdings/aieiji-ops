# Chatwork MCP server config (1106PC で .env として配置)
# 既存 orchestrator/.env の CHATWORK_API_TOKEN をコピーして使用する。

# Chatwork API トークン (必須)
CHATWORK_API_TOKEN=__paste_real_token_here__

# 自分の account_id (任意・空なら起動時に GET /me で自動取得)
# 1772516 = 社長 (三箇栄司) の account_id (1106PC orchestrator がサンプル3 で発見)
CHATWORK_MY_ACCOUNT_ID=1772516

# HTTP ポート (任意・デフォルト 3000)
PORT=3000

# ログレベル (任意・info/debug/warn/error)
LOG_LEVEL=info

# 監査ログのファイルパス (任意・デフォルト C:\aieiji-ops\logs\chatwork_audit.jsonl)
# AUDIT_LOG_PATH=C:\aieiji-ops\logs\chatwork_audit.jsonl

# Kill switch のファイルパス (任意・デフォルト C:\aieiji-ops\PAUSE)
# このファイルを作成すると送信が即時ブロックされる。
# PAUSE_FILE_PATH=C:\aieiji-ops\PAUSE
