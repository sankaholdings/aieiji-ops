# Secrets / credentials
.env
.env.*
*token*.txt
*secret*
*credentials*
# Exception: ADRs can mention "secret" or "credentials" in titles/filenames
!docs/ADR/*.md
# Exception: .env.example is a public template (no secrets)
!**/.env.example
mf_token.txt
*.key
*.pem
gmail_token.json
gmail_credentials.json

# Logs / caches
*.log
__pycache__/
*.pyc
.pytest_cache/

# OS / Editor
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# Kill switch (local only)
PAUSE

# Output / temp
tmp/
output/

# Runtime logs (local only)
logs/
orchestrator/.env

# Bridge state (local only, Phase B0+)
bridge/state/

# MCP servers (ADR-0009)
mcp-servers/*/node_modules/
mcp-servers/*/dist/
mcp-servers/*/.env
mcp-servers/*/.env.local
mcp-servers/*/coverage/
mcp-servers/*/.turbo/
